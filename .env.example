PORT=3000
PARSER_URL=http://localhost:3001
ENRICHMENT_URL=http://localhost:3002
TARIFF_URL=http://localhost:3003
DIGIKEY_CLIENT_ID=your_digikey_client_id_here
DIGIKEY_CLIENT_SECRET=your_digikey_client_secret_here
AWS_REGION=us-west-2

# DynamoDB tables provisioned by prokuroInfrastructureCDK (PartsStorage).
# Use default AWS credential chain (env / profile / IAM).
PARTS_TABLE=prokuro-parts
UNRESOLVED_TABLE=prokuro-unresolved

# OTel metrics: leave disabled for local/test (no CloudWatch export cost)
OTEL_SDK_DISABLED=true

# Digi-Key pacing
DIGIKEY_MIN_INTERVAL_MS=750
DIGIKEY_MAX_PER_DAY=1000
# DIGIKEY_MAX_PER_MINUTE=120

# Optional: override daily Digi-Key refresh interval (default 86400).
# ENRICHMENT_DAILY_SYNC_SECS=86400
